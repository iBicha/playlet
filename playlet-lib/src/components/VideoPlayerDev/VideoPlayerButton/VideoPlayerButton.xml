<component name="VideoPlayerButton" extends="Group">
    <!-- Round icon button. Focus is virtual: `focused` is an input driven by the coordinator (real focus
         stays on the Video node), so this never joins the SceneGraph focus chain. -->
    <interface>
        <field id="backgroundColor" type="color" value="#3C3C3C" />
        <field id="focusedBackgroundColor" type="color" value="#DDDDDD" />

        <field id="iconUri" type="uri" alias="icon.uri" />
        <field id="iconUri2" type="uri" alias="icon2.uri" />
        <field id="toggleState" type="boolean" value="true" /> <!-- true shows icon, false shows icon2 -->

        <field id="iconColor" type="color" value="#DDDDDD" />
        <field id="focusedIconColor" type="color" value="#262626" />

        <field id="focused" type="boolean" value="false" />
        <!-- pulse the scale nudge: confirms a press that didn't move focus (Left/Right at the row's end). -->
        <field id="nudge" type="boolean" alwaysNotify="true" />
    </interface>
    <children>
        <Group id="anchor">
            <Poster id="background" uri="pkg:/images/icons/player/white-circle.png" width="42" height="42">
                <Poster id="icon" width="42" height="42" />
                <Poster id="icon2" width="42" height="42" visible="false" />
            </Poster>
        </Group>
        <!-- subtle ButtonEx-style scale pulse, played on focus gain and on `nudge`. -->
        <Animation id="nudgeAnim" optional="true" duration="0.15">
            <Vector2DFieldInterpolator id="nudgeScale"
                key="[ 0.0, 0.5, 1.0 ]"
                keyValue="[ [ 1.0, 1.0 ], [ 1.05, 1.05 ], [ 1.0, 1.0 ] ]"
                fieldToInterp="anchor.scale" />
        </Animation>
    </children>
</component>
