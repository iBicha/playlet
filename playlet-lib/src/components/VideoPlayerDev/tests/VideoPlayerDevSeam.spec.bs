' Device-seam conformance: drives the REAL coordinator (via VideoPlayerDevMock — a Group whose device fields are
' inert and spec-driven) through scripted device-state sequences the real Roku Video won't produce on command.
' This is the harness that would have caught the reported wedge: the existing INV-D* are blind to it (during the
' wedge state="buffering", so "transport => state<>playing" was SATISFIED). The NEW property is P-seam.
import "pkg:/components/VideoPlayerDev/PlayerCoordinatorLogic.bs"
import "pkg:/components/VideoPlayerDev/TransportController.bs"
import "pkg:/components/VideoPlayerDev/VideoNode.bs"
import "pkg:/source/utils/RemoteKeys.bs"

namespace Tests

    @SGNode("VideoPlayerDevMock")
    @suite
    class VideoPlayerDevSeamTests extends Rooibos.BaseTestSuite

        protected override function beforeEach()
            m.top.callFunc("TestSetup")
            ' first frame: one state->playing opens the brain's ready-gate (transport input accepted).
            m.top.callFunc("TestSetState", VideoState.Playing)
        end function

        function Snap() as object
            return m.top.callFunc("TestSnapshot")
        end function

        @describe("device seam")

        @it("mock stands up the real coordinator (Init + OnNodeReady ran against the faked device)")
        function _()
            snap = m.Snap()
            m.assertEqual(snap.transportMode, TransportController.Mode.Idle)
            m.assertFalse(snap.seekSettling)
        end function

        ' P-SEAM: the coordinator must NOT pause the device while a play-through seek it issued is still settling.
        ' This is the wedge's root: the old code slammed control=pause on the in-flight seek -> buffering<->paused
        ' forever. It fails on the old code at the "rescrub while settling" step; passes on the new (deferred).
        @it("commit -> immediate re-scrub does NOT pause the still-settling seek; freezes cleanly only once it reaches playing")
        function _()
            ' enter scrub (normal freeze: no seek in flight yet).
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            m.top.callFunc("TestSetState", VideoState.Paused) ' the scrub froze the device
            mid = m.Snap()
            m.assertEqual(mid.transportMode, TransportController.Mode.Scrub)
            m.assertEqual(mid.control, VideoControl.Pause) ' a normal scrub DOES freeze (no settling seek)

            ' commit -> the brain emits resume+seek and marks seekSettling (a play-through seek is now in flight).
            m.top.callFunc("TestKey", RemoteKeys.Ok, true)
            afterCommit = m.Snap()
            m.assertTrue(afterCommit.seekSettling, "commit must mark a play-through seek settling")
            m.assertEqual(afterCommit.transportMode, TransportController.Mode.Idle)

            ' the device is still resolving the seek...
            m.top.callFunc("TestSetState", VideoState.Buffering)

            ' ...and the user IMMEDIATELY re-scrubs. THE PROPERTY: the coordinator must DEFER the freeze, NOT pause.
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            settling = m.Snap()
            m.assertEqual(settling.transportMode, TransportController.Mode.Scrub)
            m.assertTrue(settling.seekSettling, "the seek is still in flight")
            m.assertNotEqual(settling.control, VideoControl.Pause, "P-SEAM VIOLATION: paused the device mid-seek (the wedge) — the freeze was not deferred")

            ' the seek finally lands -> the device reaches playing -> now the guard freezes cleanly.
            m.top.callFunc("TestSetState", VideoState.Playing)
            settled = m.Snap()
            m.assertFalse(settled.seekSettling, "reaching playing clears the settling flag")
            m.assertEqual(settled.control, VideoControl.Pause, "after the seek settles, the transport freezes the playing video")
        end function

        ' P-TOTAL at the seam: a transport must hold INV-D1 across EVERY device state, including the ones the real
        ' device rarely produces. Only a PLAYING device under a transport gets re-paused; nothing else is touched.
        @it("under a transport, only a playing device is re-frozen; every other device state is a safe no-op")
        function _()
            ' get into a frozen scrub.
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            states = [VideoState.Buffering, VideoState.Paused, VideoState.Playing, VideoState.None, VideoState.Stopping, VideoState.Stopped]
            for each s in states
                m.top.callFunc("TestSetState", s)
                snap = m.Snap()
                m.assertEqual(snap.transportMode, TransportController.Mode.Scrub, "still scrubbing through device state " + s)
                if s = VideoState.Playing
                    m.assertEqual(snap.control, VideoControl.Pause, "a playing device under a transport is re-frozen (INV-D1)")
                end if
            end for
        end function

        ' The one live case where the re-freeze must NOT happen: the sliding DVR tail overtook the frozen
        ' playhead, and the device force-resumes such a pause on every manifest refresh (verified on device) —
        ' re-pausing loops 1/s forever. The coordinator resolves forward instead: a commit from a cursor
        ' floored a margin above the tail.
        @it("a live playhead the sliding tail overtook resolves forward (commit), not a re-pause loop")
        function _()
            ' 12h stream at the edge, 4h window -> floor = 8h. Park the playhead 5s above the floor (a deep
            ' rewind), then freeze: the frozen position sits inside the tail margin the device cannot hold.
            m.top.callFunc("TestSetLive", 43200000)
            m.top.position = 28805.0 ' fires the REAL OnPosition -> brain playhead 28805000ms
            m.top.callFunc("TestKey", RemoteKeys.Left, true) ' freeze; the cursor clamps at the floor
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            mid = m.Snap()
            m.assertEqual(mid.transportMode, TransportController.Mode.LiveDvr)
            m.assertEqual(mid.control, VideoControl.Pause)

            ' the device force-resumes the doomed pause (what the real player does each manifest refresh).
            m.top.callFunc("TestSetState", VideoState.Playing)
            snap = m.Snap()
            m.assertEqual(snap.transportMode, TransportController.Mode.Idle, "the transport resolved instead of fighting")
            m.assertEqual(snap.control, VideoControl.Resume, "resumed forward, not re-paused")
            m.assertEqual(Int(m.top.seek * 1000), 28860000, "the resume parks a full margin above the trigger (28800s + 60s)")
            ' the resolution telemeters at info level (never as a heal) with its per-content ordinal.
            sent = m.global.telemetry.LogEvent
            m.assertEqual(sent.level, "info")
            m.assertTrue(sent.message.InStr("INV-D1 tail-resolve") = 0, "got: " + sent.message)
            m.assertTrue(sent.message.InStr("resolve=1") > 0)
        end function

        @it("heal telemetry stops at the cap while the occurrences keep counting")
        function _()
            ' a frozen VOD scrub the device keeps flipping to playing: 5 heals, but only 3 events may leave.
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            for i = 1 to 5
                m.top.callFunc("TestSetState", VideoState.Playing)
            end for
            sent = m.global.telemetry.LogEvent
            m.assertTrue(sent.message.InStr("heal=3") > 0, "telemetry must stop at the 3rd heal; last sent: " + sent.message)
        end function

        @it("a sentinel-valued duration report cannot anchor the live-edge fallback clock")
        function _()
            m.top.callFunc("TestSetLive", 300000)
            ' the 999999s live seek echoing back through the single-precision duration field.
            m.top.duration = 999998.976
            m.assertEqual(m.Snap().brainEdgeMs, 300000, "the sentinel echo must not move the edge")
            ' a real duration report anchors the fallback and re-feeds the edge.
            m.top.duration = 400.0
            m.assertEqual(m.Snap().brainEdgeMs, 400000)
        end function

        ' An external resume (the linked phone via Lounge) under an active transport must TAKE OVER: VPD never
        ' resumes under a transport itself, so a resume here is the phone's. It cancels the scrub and plays.
        @it("an external Lounge resume under a transport takes over: cancels the scrub and lets it play")
        function _()
            ' enter scrub -> the brain freezes the device (control=pause).
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            m.top.callFunc("TestSetState", VideoState.Paused)
            mid = m.Snap()
            m.assertEqual(mid.transportMode, TransportController.Mode.Scrub)
            m.assertEqual(mid.control, VideoControl.Pause)

            ' the phone seeks + resumes: Lounge sets control=resume directly on the player node.
            m.top.callFunc("TestSetControl", VideoControl.Resume)
            after = m.Snap()
            m.assertEqual(after.transportMode, TransportController.Mode.Idle, "the external resume cancels the transport")
            m.assertEqual(after.control, VideoControl.Resume, "the video plays (the phone action wins)")
            m.assertTrue(after.autoplay, "autoplay restored so a settling seek won't re-freeze the takeover")
        end function

        @it("the error dialog displays every captured error field, not just the category")
        function _()
            ' Real Roku Video error captured on device (an http stream failure, 502 manifest).
            errStr = "reader pick stream error:HTTP error:Transfer error: HTTP response code said error response code:(502):502:extra:content_id:24:err_clip_idx:0:etype:buffer:program_id:"
            snap = m.top.callFunc("TestPlaybackErrorDialog", {
                videoId: "dQw4w9WgXcQ"
                errorMsg: "There was an error in the HTTP response.  This could mean that malformed HTTP headers or an HTTP error code was returned."
                errorCode: -1
                errorStr: errStr
                ' the stream list is exhausted (no next url) -> dialog, not retry.
                errorInfo: { category: "http", source: "buffer:reader", clipid: 24, ignored: false, dbgmsg: errStr }
            })

            body = snap.message
            m.assertTrue(body.Instr("errorMsg: There was an error in the HTTP response") >= 0, "dialog dropped errorMsg")
            m.assertTrue(body.Instr("errorCode: -1") >= 0, "dialog dropped errorCode")
            m.assertTrue(body.Instr("errorStr: reader pick stream error") >= 0, "dialog dropped errorStr")
            m.assertTrue(body.Instr("category: http") >= 0, "dialog dropped errorInfo.category")
            m.assertTrue(body.Instr("source: buffer:reader") >= 0, "dialog dropped errorInfo.source")
            m.assertTrue(body.Instr("clipid: 24") >= 0, "dialog dropped errorInfo.clipid")
            m.assertTrue(body.Instr("ignored: false") >= 0, "dialog dropped errorInfo.ignored")
            m.assertTrue(body.Instr("dbgmsg: reader pick stream error") >= 0, "dialog dropped errorInfo.dbgmsg")
            m.assertTrue(snap.title.Instr("dQw4w9WgXcQ") >= 0, "dialog title dropped the videoId")
        end function

        ' Up/Down reveal the chrome when it is hidden in idle (they otherwise do nothing).
        @it("Up reveals the chrome when it is hidden in idle")
        function _()
            m.assertFalse(m.Snap().chromeShown) ' starts hidden after setup
            m.top.callFunc("TestKey", RemoteKeys.Up, true)
            m.assertTrue(m.Snap().chromeShown, "Up revealed the chrome")
        end function

        ' =========================================================================================
        ' Back ladder — a transport active > the chrome visible in any form > nothing left to dismiss.
        ' =========================================================================================

        ' Rung 1: a transport active -> Back cancels it and KEEPS WATCHING (never exits). VOD stays exactly
        ' where the freeze put it: PAUSED (no resume intent — the settled cancel/commit asymmetry). Also
        ' re-arms auto-hide: OnAutoHideFire no-ops without rearming itself (repeat=false) while a transport is
        ' active, so a scrub that outlasted the 5s timer leaves it dead — TestKillAutoHide models that fired
        ' state first, otherwise the "start" read here would pass even with the rearm deleted (a fired Timer
        ' still READS control="start").
        @it("Back while a VOD transport is active cancels it (rung 1): keeps watching, stays paused, chrome stays up, auto-hide is rearmed")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Left, true) ' transport-key reveal + freeze the scrub
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            mid = m.Snap()
            m.assertEqual(mid.transportMode, TransportController.Mode.Scrub)
            m.assertTrue(mid.chromeShown)
            m.assertEqual(mid.control, VideoControl.Pause, "the scrub froze the device")
            m.top.callFunc("TestKillAutoHide") ' the 5s auto-hide fired mid-scrub: timer dead

            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            after = m.Snap()
            m.assertEqual(after.transportMode, TransportController.Mode.Idle, "Back cancelled the transport")
            m.assertFalse(m.top.videoQueue.closePlayer, "Back must NOT exit while a transport was active -- it only cancels")
            m.assertEqual(after.control, VideoControl.Pause, "a VOD cancel emits NO intent: the device stays where the freeze put it (paused)")
            m.assertTrue(after.chromeShown, "the HUD stays up; only the transport is cancelled")
            m.assertEqual(after.autoHideControl, "start", "auto-hide is rearmed -- else the chrome would be stuck shown (the timer died mid-transport)")
        end function

        ' Rung 1 on LIVE: cancel also RESUMES at the frozen playhead, without a seek. Idle-paused live is a
        ' dead end (OK only toggles the HUD on live, and the paused playhead drifts toward the DVR floor
        ' until the device force-resumes it anyway), so the cancel emits the resume itself.
        @it("Back while a live transport is active (rung 1): cancels AND resumes at the frozen playhead, no seek")
        function _()
            m.top.callFunc("TestSetLive", 43200000) ' 12h stream at the edge, 4h window
            seekBefore = m.top.seek
            m.top.callFunc("TestKey", RemoteKeys.Left, true) ' rewind: LiveDvr + freeze
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            mid = m.Snap()
            m.assertEqual(mid.transportMode, TransportController.Mode.LiveDvr)
            m.assertEqual(mid.control, VideoControl.Pause, "the live transport froze the device")

            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            after = m.Snap()
            m.assertEqual(after.transportMode, TransportController.Mode.Idle, "Back cancelled the transport")
            m.assertFalse(m.top.videoQueue.closePlayer)
            m.assertEqual(after.control, VideoControl.Resume, "a LIVE cancel resumes -- idle-paused live has no OK-resume and cannot hold anyway")
            m.assertEqual(m.top.seek, seekBefore, "the resume carries NO seek: playback continues from the frozen playhead, still behind the edge")
        end function

        ' Rung 2: idle, chrome shown -> Back dismisses it with the SAME animated fade auto-hide uses
        ' (HideChrome), not the instant HideChromeNow, and does not exit.
        @it("Back while idle with the chrome up dismisses it via the animated fade (rung 2): does not exit")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' idle reveal, no transport
            mid = m.Snap()
            m.assertEqual(mid.transportMode, TransportController.Mode.Idle)
            m.assertTrue(mid.chromeShown)

            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            after = m.Snap()
            m.assertFalse(m.top.videoQueue.closePlayer, "Back must NOT exit while the chrome was up -- it only dismisses the HUD")
            m.assertTrue(after.chromeFadingOut, "Back used the animated HideChrome fade (matches auto-hide), not the instant HideChromeNow")
        end function

        ' Rung 3: idle, chrome mid fade-out (the user can still SEE it) -> Back is CONSUMED but does nothing:
        ' the dismissal is already underway, so the fade just keeps running. Only once it completes (modeled
        ' via TestFinishChromeFadeOut — test time can't wait out the 0.3s) does Back close.
        @it("Back while the chrome is fading out no-ops (rung 3): the fade continues, no exit; Back closes only once fully hidden")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' reveal...
            m.top.callFunc("TestKey", RemoteKeys.Back, true) ' ...dismiss: now fading out
            m.assertTrue(m.Snap().chromeFadingOut)

            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            after = m.Snap()
            m.assertFalse(m.top.videoQueue.closePlayer, "a Back while the chrome is still visible must NOT exit")
            m.assertTrue(after.chromeFadingOut, "the fade keeps running -- Back neither restarts, completes, nor cancels it")

            ' the fade completes -> fully hidden -> NOW Back closes.
            m.top.callFunc("TestFinishChromeFadeOut")
            m.assertFalse(m.Snap().chromeFadingOut)
            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            m.assertTrue(m.top.videoQueue.closePlayer, "once fully hidden, Back closes")
        end function

        ' Rung 4: idle, chrome fully hidden -> nothing left to dismiss -> close (today's original behavior).
        @it("Back while idle with the chrome already hidden closes the player (rung 4, unchanged)")
        function _()
            m.assertFalse(m.Snap().chromeShown, "starts hidden after setup")
            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            m.assertTrue(m.top.videoQueue.closePlayer, "nothing left to dismiss -> Back closes")
        end function

        ' The full ladder driven in one sequence: cancel transport -> dismiss chrome -> no-op while fading ->
        ' close once hidden. Proves the rungs compose correctly across successive presses, not just in isolation.
        @it("the full Back ladder in sequence: cancel transport -> dismiss chrome -> no-op while fading -> close once hidden")
        function _()
            ' step 1: transport active -> cancel, keep watching, chrome still up.
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            m.assertEqual(m.Snap().transportMode, TransportController.Mode.Scrub)
            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            step1 = m.Snap()
            m.assertEqual(step1.transportMode, TransportController.Mode.Idle)
            m.assertFalse(m.top.videoQueue.closePlayer)
            m.assertTrue(step1.chromeShown, "rung 1 leaves the chrome up")

            ' step 2: idle, chrome still up from rung 1 -> Back dismisses it (animated).
            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            step2 = m.Snap()
            m.assertFalse(m.top.videoQueue.closePlayer)
            m.assertTrue(step2.chromeFadingOut, "rung 2 dismisses via the animated fade")

            ' step 3: still fading out (the user can see it) -> Back is consumed, the fade keeps running.
            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            step3 = m.Snap()
            m.assertFalse(m.top.videoQueue.closePlayer, "rung 3 never exits")
            m.assertTrue(step3.chromeFadingOut, "rung 3 lets the fade finish on its own")

            ' step 4: the fade completes -> chrome fully hidden -> nothing left to dismiss -> close.
            m.top.callFunc("TestFinishChromeFadeOut")
            m.top.callFunc("TestKey", RemoteKeys.Back, true)
            m.assertTrue(m.top.videoQueue.closePlayer, "rung 4: Back closes")
        end function

        ' The point of the bar-default: Left/Right seek and OK pauses with no navigation at all, straight off a
        ' fresh reveal. Pinned as its own test rather than left as a side effect of the tier round-trip tests.
        @it("a fresh idle reveal defaults focus to the bar: Left/Right seek and OK pauses with no navigation")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Ok, true) ' reveal (VOD, playing, chrome hidden -> shown)
            snap = m.Snap()
            m.assertTrue(snap.chromeShown)
            m.assertEqual(snap.focusTarget, PlayerCoordinatorLogic.FocusTarget.Bar, "the bar is focused immediately, no Down needed")

            ' Left seeks right away — the buttons tier is not intercepting it.
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            m.assertEqual(m.Snap().transportMode, TransportController.Mode.Scrub, "Left scrubs immediately from the default bar focus")
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            m.top.callFunc("TestKey", RemoteKeys.Ok, true) ' commit -> idle (a commit also hides the chrome)
            m.assertEqual(m.Snap().transportMode, TransportController.Mode.Idle)

            ' OK pauses directly from the bar tier too — pausing was never gated on the Buttons tier. Re-reveal
            ' first (the commit above hid the chrome), landing back on the bar by default, then OK pauses.
            m.top.callFunc("TestKey", RemoteKeys.Ok, true) ' fresh reveal -> bar tier again
            revealed = m.Snap()
            m.assertTrue(revealed.chromeShown)
            m.assertEqual(revealed.focusTarget, PlayerCoordinatorLogic.FocusTarget.Bar)
            m.top.callFunc("TestKey", RemoteKeys.Ok, true) ' now pauses
            m.assertEqual(m.Snap().control, VideoControl.Pause, "OK pauses directly from the bar tier")
        end function

        ' The "● LIVE" reveal hold: an idle live reveal flashes the badge briefly (forceLiveBadge) before the
        ' label swaps to the time-behind-edge — but any live transport must show the TIME immediately (the user
        ' seeks by it), so a transport-key reveal never starts the hold and a scrub mid-hold releases it.
        @it("an idle live reveal holds ● LIVE until the hold timer fires")
        function _()
            m.top.callFunc("TestSetLive", 43200000) ' 12h stream at the edge
            m.top.callFunc("TestKey", RemoteKeys.Ok, true) ' idle live reveal (chrome toggle, no pause)
            snap = m.Snap()
            m.assertTrue(snap.chromeShown)
            m.assertTrue(snap.forceLiveBadge, "the reveal forces the badge for the hold window")
            m.top.callFunc("TestFireLiveBadgeHold")
            m.assertFalse(m.Snap().forceLiveBadge, "the hold releases -> the offset label may show")
        end function

        @it("a live scrub from HIDDEN reveals with the time immediately (no ● LIVE hold)")
        function _()
            m.top.callFunc("TestSetLive", 43200000)
            m.top.callFunc("TestKey", RemoteKeys.Left, true) ' rewind from hidden -> transport-key reveal
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            snap = m.Snap()
            m.assertEqual(snap.transportMode, TransportController.Mode.LiveDvr, "Left entered the live rewind")
            m.assertTrue(snap.chromeShown)
            m.assertFalse(snap.forceLiveBadge, "no hold on a transport reveal — the offset must be readable at once")
        end function

        @it("a live SCAN from hidden (Rev) shows the time immediately — atLiveEdge alone must not keep the badge")
        function _()
            ' a scan's cursor hasn't moved on the press (it moves on the first timer tick), so atLiveEdge is
            ' still true at entry — the bar must suppress the badge for the active transport, not wait a tick.
            m.top.callFunc("TestSetLive", 43200000)
            m.top.callFunc("TestKey", RemoteKeys.Rewind, true)
            m.top.callFunc("TestKey", RemoteKeys.Rewind, false)
            snap = m.Snap()
            m.assertEqual(snap.transportMode, TransportController.Mode.LiveDvr, "Rev entered the live scan")
            m.assertTrue(snap.chromeShown)
            m.assertFalse(snap.liveBadgeShown, "the ● LIVE badge is gone on the very first press")
            m.assertEqual(snap.barRemainingText, "0:00", "the offset is readable immediately (counts up from 0:00)")
        end function

        @it("a live scrub started DURING the reveal hold releases the badge immediately")
        function _()
            m.top.callFunc("TestSetLive", 43200000)
            m.top.callFunc("TestKey", RemoteKeys.Ok, true) ' reveal -> hold running, bar tier by default
            m.assertTrue(m.Snap().forceLiveBadge)
            m.top.callFunc("TestKey", RemoteKeys.Left, true) ' scrub back while the hold is still running
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            snap = m.Snap()
            m.assertEqual(snap.transportMode, TransportController.Mode.LiveDvr)
            m.assertFalse(snap.forceLiveBadge, "the transport releases the hold — time shows, not ● LIVE")
        end function

        ' The button tier remembers its highlighted button across a buttons->bar->buttons round-trip; only a
        ' fresh reveal (the row was hidden) resets the highlight to play/pause. A fresh reveal lands on the bar
        ' tier by default, so reaching the buttons takes an explicit Up first.
        @it("the button tier keeps its focused button across a bar round-trip; a fresh reveal resets it")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' reveal -> bar tier (default)
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' bar -> buttons tier, play/pause focused
            snap = m.Snap()
            m.assertTrue(snap.chromeShown)
            m.assertEqual(snap.focusedButton, 0)
            ' highlight minimize, drop to the bar, come back up: still minimize.
            m.top.callFunc("TestKey", RemoteKeys.Right, true)
            m.assertEqual(m.Snap().focusedButton, 1)
            m.top.callFunc("TestKey", RemoteKeys.Down, true)
            m.top.callFunc("TestKey", RemoteKeys.Up, true)
            m.assertEqual(m.Snap().focusedButton, 1, "the highlight survives the round-trip")
            ' hide the chrome (scrub from the bar tier, then commit) -> the NEXT reveal starts at play/pause.
            m.top.callFunc("TestKey", RemoteKeys.Down, true)
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            m.top.callFunc("TestKey", RemoteKeys.Ok, true) ' commit -> chrome hides
            m.assertFalse(m.Snap().chromeShown)
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' fresh reveal -> bar tier
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' bar -> buttons tier
            m.assertEqual(m.Snap().focusedButton, 0, "a fresh reveal resets the highlight")
        end function

        ' Up at the top tier (the buttons) has nowhere to go; the press must still visibly land — it pulses
        ' (nudges) the focused button instead of being swallowed.
        @it("Up at the buttons tier nudges the focused button instead of moving focus")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' reveal -> bar tier (default)
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' bar -> buttons tier
            before = m.Snap()
            m.assertEqual(before.focusTarget, PlayerCoordinatorLogic.FocusTarget.Buttons)
            m.assertEqual(before.nudgeCount, 0, "moving focus does not nudge")
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' nowhere to go up
            after = m.Snap()
            m.assertEqual(after.nudgeCount, 1, "the no-op Up pulsed the focused button")
            m.assertEqual(after.focusTarget, PlayerCoordinatorLogic.FocusTarget.Buttons, "focus stays on the buttons")
            m.assertEqual(after.focusedButton, before.focusedButton, "the highlight is untouched")
        end function

        ' A press that GOES somewhere must not nudge: Left/Right inside the row, Up/Down between the tiers.
        @it("a press that moves focus does not nudge")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' reveal -> bar tier (default)
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' bar -> buttons tier, play/pause
            m.top.callFunc("TestKey", RemoteKeys.Right, true) ' play/pause -> minimize
            m.top.callFunc("TestKey", RemoteKeys.Down, true) ' buttons -> bar
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' bar -> buttons
            m.top.callFunc("TestKey", RemoteKeys.Left, true) ' minimize -> play/pause
            m.assertEqual(m.Snap().nudgeCount, 0, "every press moved focus; none may pulse")
        end function

        ' Left/Right clamped at the row's ends pulse the focused button (the original nudge path, at the seam).
        @it("Left/Right clamped at the row ends nudge the focused button")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' reveal -> bar tier (default)
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' bar -> buttons tier, play/pause (leftmost)
            m.top.callFunc("TestKey", RemoteKeys.Left, true) ' clamped at the left end
            m.assertEqual(m.Snap().nudgeCount, 1)
            m.top.callFunc("TestKey", RemoteKeys.Right, true) ' -> minimize (rightmost)
            m.top.callFunc("TestKey", RemoteKeys.Right, true) ' clamped at the right end
            snap = m.Snap()
            m.assertEqual(snap.nudgeCount, 2)
            m.assertEqual(snap.focusedButton, 1, "the clamp held the highlight at the end")
        end function

        ' Down at the bar tier (the bottom, and the default on reveal) is a no-op: consumed, no nudge.
        @it("Down at the bar tier is consumed without a nudge")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' reveal -> bar tier (default)
            m.top.callFunc("TestKey", RemoteKeys.Down, true) ' nowhere to go down
            snap = m.Snap()
            m.assertEqual(snap.focusTarget, PlayerCoordinatorLogic.FocusTarget.Bar, "focus stays on the bar")
            m.assertEqual(snap.nudgeCount, 0)
        end function

        ' A keep-playing seek issued while PAUSED must preserve the pause: the device auto-resumes on any seek
        ' (autoplayAfterSeek only governs rebuffer-resume per the Video docs), so the coordinator re-pauses on
        ' the playing edge the auto-resume produces.
        @it("a keep-playing seek issued while paused re-pauses when the device auto-resumes")
        function _()
            ' pause from idle.
            m.top.callFunc("TestKey", RemoteKeys.Play, true)
            m.top.callFunc("TestSetState", VideoState.Paused)
            m.assertEqual(m.Snap().control, VideoControl.Pause)
            ' InstantReplay from paused idle = a keep-playing seek (no control, just a seek).
            m.top.callFunc("TestKey", RemoteKeys.Replay, true)
            ' scrub the control to a neutral value so the assertion below can only pass via the re-pause.
            m.top.callFunc("TestSetControl", VideoControl.None)
            ' the seek lands and the device auto-resumes...
            m.top.callFunc("TestSetState", VideoState.Playing)
            ' ...and the coordinator restores the pause.
            m.assertEqual(m.Snap().control, VideoControl.Pause, "the paused state survives the keep-playing seek")
        end function

        ' Committing a scrub at the very end finishes playback (PlayNext/close) instead of seeking into the
        ' last instants and fighting the device's EOF auto-resume (the residual re-pause loop).
        @it("a commit at the end of content finishes playback instead of seeking")
        function _()
            m.top.duration = 100
            m.top.position = 95
            ' two Right presses: snap 95s -> 94s grid, then 96s -> 98s = duration - epsilon -> at the end.
            m.top.callFunc("TestKey", RemoteKeys.Right, true)
            m.top.callFunc("TestKey", RemoteKeys.Right, false)
            m.top.callFunc("TestKey", RemoteKeys.Right, true)
            m.top.callFunc("TestKey", RemoteKeys.Right, false)
            m.assertEqual(m.Snap().transportMode, TransportController.Mode.Scrub)
            m.top.callFunc("TestKey", RemoteKeys.Ok, true) ' commit at the end -> finish
            after = m.Snap()
            m.assertEqual(after.transportMode, TransportController.Mode.Idle)
            m.assertTrue(m.top.videoQueue.closePlayer, "no next video -> the finish closed the player")
        end function

        ' Play always means play/pause: it must NOT activate whatever button happens to be highlighted.
        @it("Play toggles play/pause even while a non-play button is highlighted")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' reveal -> bar tier (default)
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' bar -> buttons tier
            m.top.callFunc("TestKey", RemoteKeys.Right, true) ' highlight minimize
            m.assertEqual(m.Snap().focusedButton, 1)
            m.top.callFunc("TestKey", RemoteKeys.Play, true) ' must pause, not minimize
            snap = m.Snap()
            m.assertEqual(snap.control, VideoControl.Pause, "Play paused the (playing) video")
            m.assertEqual(snap.focusedButton, 1, "the highlight is untouched")
        end function

        ' The coordinator twin of the brain's unmodeled-axis meta-test: every m.* field on the coordinator must
        ' be consciously classified here. A NEW coordinator field fails this until someone decides what it is —
        ' a state axis needs transition coverage, a flag needs its consuming path tested.
        @it("every coordinator m.* field is consciously classified (no unmodeled coordinator axis)")
        function _()
            classified = {}
            ' bound deps (AutoBind interface aliases) + the test stub's own copies.
            for each name in ["container", "jobQueue", "preferences", "invidious", "videoQueue", "loungeService", "notifications", "appController", "webServer", "innertube"]
                classified[name] = "dep"
            end for
            ' controllers (plain .bs class instances).
            for each name in ["transport", "sponsorblock"]
                classified[name] = "controller"
            end for
            ' cached child nodes / timers / animations / reusable helpers (structure, not state).
            for each name in ["chrome", "titleLabel", "secondaryTitleLabel", "clock", "bifDisplay", "trickPlayBar", "spinner", "largePause", "buttonRow", "fullScreenHint", "autoHide", "transportTimer", "liveBadgeHold", "liveEdgeClock", "fullScreenHintTimer", "chromeFadeIn", "chromeFadeOut", "minimize", "nowDateTime"]
                classified[name] = "node"
            end for
            ' in-flight job handles.
            for each name in ["videoContentJob", "sponsorBlockSegmentsJob", "markVideoWatchedJob"]
                classified[name] = "job"
            end for
            ' STATE AXES — discrete coordinator state; each needs its transitions covered by a seam test.
            for each name in ["chromeMode", "focusTarget", "focusedButton", "armedTimerId"]
                classified[name] = "axis"
            end for
            ' flags / scratch — one-shot latches and counters with a single consuming path.
            for each name in ["onCloseCalled", "ignoreNextFinished", "videoPlayedSuccessfully", "firstFrameSeen", "showFullScreenHint", "repauseAfterSeek", "seekToPercent", "watchTimeMarker", "reportWatchTime", "errorDialogNode", "lastCommitSeq", "lastFinishSeq", "liveAstSeconds", "liveFallbackEdgeMs", "liveFallbackAtSeconds", "liveBadgeHoldActive", "healCount", "tailResolveCount"]
                classified[name] = "flag"
            end for
            ' NOT coordinator state — node-scope + test-environment entries, pinned EXPLICITLY (no hidden
            ' filtering) so an unexpected newcomer (a Rooibos upgrade, a new library memo) fails this test and
            ' demands a conscious classification. Presence is optional: these depend on the environment and on
            ' which tests ran before this one (e.g. DialogUtils' memo appears only after the error-dialog test).
            for each name in ["top", "global", "testrunner", "testsuite", "scene", "_devicedisplaywidth", "__globalstubs", "__promises__deviceinfo"]
                classified[name] = "infra"
            end for

            keys = m.top.callFunc("TestCoordinatorFields")
            m.assertTrue(keys.Count() >= 30, "reflection found only " + keys.Count().ToStr() + " fields — the walk may be vacuous")
            unknown = []
            for each key in keys
                if not classified.DoesExist(key)
                    unknown.Push(key)
                end if
            end for
            m.assertTrue(unknown.Count() = 0, "UNMODELED coordinator field(s) " + FormatJson(unknown) + " — classify them in this meta-test (axis fields need transition coverage)")
            ' reverse: no classified COORDINATOR field has rotted away (infra entries are optional-presence).
            seen = {}
            for each key in keys
                seen[key] = true
            end for
            for each name in classified
                if classified[name] <> "infra"
                    m.assertTrue(seen.DoesExist(name), "stale classified field '" + name + "' is no longer on the coordinator")
                end if
            end for
        end function

        ' PiP captions (regression: subtitles stopped after shrink->grow). With enableUI=false the OS leaves
        ' captions blank after a PiP restore; minimize must suppress and restore must release — the
        ' suppress->release refresh re-engages OS caption rendering.
        @it("PiP minimize suppresses captions; restore releases them")
        function _()
            container = m.top.container
            m.assertFalse(m.Snap().suppressCaptions, "captions shown while fullscreen")
            container.fullscreen = false
            m.assertTrue(m.Snap().suppressCaptions, "captions suppressed while minimized")
            container.fullscreen = true
            m.assertFalse(m.Snap().suppressCaptions, "captions released on restore")
        end function

        ' The PiP-toggle-after-close crash (captured on device): OnClose drops m.sponsorblock, so a leaked
        ' container observer makes the next fullscreen flip crash OnFullScreenChange (&hf3 on SetVisible). The
        ' fix is unobserve-on-close + the onCloseCalled guard; a regression CRASHES this test. Kept LAST in the
        ' suite: OnClose detaches the node from its parent.
        @it("a closed player ignores container fullscreen flips (the PiP-toggle-after-close crash)")
        function _()
            container = m.top.container
            ' sanity: pre-close the observer is live — a minimize hides all player UI.
            m.top.callFunc("TestKey", RemoteKeys.Up, true) ' reveal the chrome
            m.assertTrue(m.Snap().chromeShown)
            container.fullscreen = false
            m.assertFalse(m.Snap().chromeShown, "minimize hides the chrome now")
            container.fullscreen = true
            ' close the player (what the queue does when replacing the video), then throw every signal a dead
            ' player might still receive at it: fullscreen flips (the * key), device edges from the async stop,
            ' a stray control/seek write, late thumbnails, a second close. OnClose unobserves them all.
            m.top.close = true
            container.fullscreen = false
            container.fullscreen = true
            m.top.callFunc("TestSetState", VideoState.Buffering)
            m.top.callFunc("TestSetState", VideoState.Playing)
            m.top.callFunc("TestSetState", VideoState.Stopped)
            m.top.callFunc("TestSetControl", VideoControl.Resume)
            m.top.position = 12.0
            m.top.duration = 99.0
            m.top.seek = 5.0
            m.top.thumbnailTiles = { x: [{ htiles: 1 }] }
            m.top.close = true
            m.assertTrue(true, "no crash: the closed player ignored all post-close traffic")
        end function

        ' Crash #1 (store: the dominant OnPosition crash, &hf3 ERR_RO3 "interface not a member"): a finish
        ' triggered from WITHIN a position tick re-enters teardown synchronously — EnforceTransportFreeze ->
        ' FinishEof -> OnPlaybackFinished -> ClosePlayer -> the queue sets player.close -> OnClose drops
        ' m.sponsorblock — then OnPosition continues to `m.sponsorblock.OnPosition()` and derefs the dropped
        ' controller. (`m.sponsorblock` is a field, so the invalid deref is &hf3, not &hec.) The OLD code crashes
        ' here; the onCloseCalled re-check after EnforceTransportFreeze bails. Kept at the END with the other
        ' closing test: OnClose detaches the node.
        @it("a finish during a position tick must not deref the dropped sponsorblock (the OnPosition ERR_RO3 crash)")
        function _()
            m.top.callFunc("TestWireQueueClose") ' the stub queue now closes the player on closePlayer, as the real one does
            m.top.duration = 100
            m.top.position = 90
            ' scrub the cursor to the end (atEof) while the actual position is NOT yet at the end.
            for i = 0 to 8
                m.top.callFunc("TestKey", RemoteKeys.Right, true)
                m.top.callFunc("TestKey", RemoteKeys.Right, false)
            end for
            m.assertEqual(m.Snap().transportMode, TransportController.Mode.Scrub)
            ' the device is PLAYING under the active transport (the INV-D1 anomaly EnforceTransportFreeze guards).
            ' Position is not yet at EOF, so this is a normal re-freeze — NOT a finish.
            m.top.callFunc("TestSetState", VideoState.Playing)
            m.assertFalse(m.Snap().onCloseCalled, "not finished yet — the position is not at EOF")
            ' NOW a position tick lands at the end -> OnPosition -> EnforceTransportFreeze -> FinishEof ->
            ' OnPlaybackFinished -> ClosePlayer -> (re-entrant) OnClose drops m.sponsorblock -> OnPosition then
            ' derefs the dropped controller. The old code faults here (&hf3); the fix bails first.
            m.top.position = 99
            ' reaching here means OnPosition survived the re-entrant teardown.
            m.assertTrue(m.Snap().onCloseCalled, "the finish closed the player from within the position tick")
        end function

        ' Also at the end (closes the player): a heal loop that ran past the telemetry cap reports its
        ' true size in one tally event when the content ends.
        @it("the close summary carries a capped heal loop's true size")
        function _()
            m.top.callFunc("TestKey", RemoteKeys.Left, true)
            m.top.callFunc("TestKey", RemoteKeys.Left, false)
            for i = 1 to 5
                m.top.callFunc("TestSetState", VideoState.Playing)
            end for
            m.top.close = true
            summary = m.global.telemetry.LogEvent
            m.assertTrue(summary.message.InStr("5 heals") > 0, "got: " + summary.message)
            m.assertTrue(summary.message.InStr("2 past the telemetry cap") > 0, "got: " + summary.message)
        end function

    end class

end namespace
