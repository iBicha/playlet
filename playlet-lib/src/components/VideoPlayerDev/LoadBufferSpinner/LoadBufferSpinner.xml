<component name="LoadBufferSpinner" extends="Group">
    <!-- Two modes: first-load overlay (title + spinner) and mid-stream buffering (spinner alone). -->
    <interface>
        <field id="mode" type="integer" value="0" /> <!-- 0=none 1=loading 2=buffering -->
        <field id="title" type="string" alias="loadingTitleLabel.text" />
        <field id="secondaryTitle" type="string" alias="loadingSecondaryTitleLabel.text" />
    </interface>
    <children>
        <!-- Title + secondary title overlay; shown only in loading mode. Static wrapped title (up to 3 lines),
             matching the Chrome title area — a ScrollingLabel marquee would repaint continuously for the whole
             load. -->
        <LayoutGroup id="loadingTitleArea" translation="[68, 40]" layoutDirection="vert" itemSpacings="[5]" visible="false">
            <Label id="loadingTitleLabel" width="900" wrap="true" maxLines="3"
                color="0xFEFEFEFF" horizAlign="left">
                <Font role="font" uri="font:BoldSystemFontFile" size="30" />
            </Label>
            <Label id="loadingSecondaryTitleLabel" width="900" height="26"
                color="0xFEFEFEFF" horizAlign="left" vertAlign="top" wrap="false">
                <Font role="font" uri="font:SystemFontFile" size="24" />
            </Label>
        </LayoutGroup>
        <!-- Shared by both modes; translation centers the 80x80 spinner. -->
        <BusySpinner id="spinner" translation="[600, 320]" visible="false" spinInterval="1"
            uri="/RokuOS/Artwork/SceneGraph/FixedTheme/Base/FHD/Spinner_MH.webp" />
    </children>
</component>
