<component name="ProfileContentNode" extends="ContentNode">
    <interface>
        <field id="type" type="string" value="invidious" />
        <field id="isSelected" type="boolean" alwaysNotify="true" />

        <field id="username" type="string" />
        <field id="serverUrl" type="string" />
        <field id="accessToken" type="string" />

        <!-- Innertube fields -->
        <field id="activeIdentifyToken" type="string" />
        <field id="selectActiveIdentityEndpoint" type="assocarray" />
        <field id="thumbnail" type="uri" />
        <field id="refreshToken" type="string" />
        <field id="scope" type="string" />
        <field id="tokenType" type="string" />
        <field id="expiresIn" type="longinteger" />
        <field id="expiresTimestamp" type="longinteger" />
        <field id="clientId" type="string" />
        <field id="clientSecret" type="string" />

        <field id="color" type="color" />

        <!-- Runtime credential state (ProfileAuthState); derived from the stored
             credential at load, mutated only by MarkNeedsReauth and re-login. -->
        <field id="authState" type="string" value="Authenticated" />

        <field id="refreshCompleted" type="boolean" alwaysNotify="true" />

        <function name="ResolveAccessToken" />
        <function name="MarkNeedsReauth" />
    </interface>
</component>
