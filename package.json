{
    "name": "playlet",
    "version": "0.48.1",
    "description": "Unofficial YouTube client for Roku",
    "devDependencies": {
        "@rokucommunity/bslint": "^0.8.44",
        "@types/crypto-js": "^4.2.2",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^25.9.3",
        "@types/xml2js": "^0.4.14",
        "argparse": "^2.0.1",
        "brighterscript": "0.72.5",
        "brighterscript-formatter": "^1.7.27",
        "convert-svg-to-png": "^0.7.1",
        "crypto-js": "^4.2.0",
        "dotenv": "^17.4.2",
        "fs-extra": "^11.3.5",
        "glob": "^13.0.6",
        "imap": "^0.8.19",
        "ip": "^2.0.1",
        "json5": "^2.2.3",
        "mailparser": "^3.9.9",
        "protocol-buffers-schema": "^3.6.1",
        "puppeteer": "^25.1.0",
        "roku-deploy": "^3.17.6",
        "roku-test-automation": "^2.2.2",
        "rooibos-roku": "5.16.4",
        "rounded-rect-9patch": "^1.1.2",
        "semver": "^7.8.4",
        "shelljs": "^0.10.0",
        "telnet-client": "^2.2.13",
        "ts-node": "^10.9.2",
        "typescript": "6.0.3",
        "xml2js": "^0.6.2",
        "yaml": "^2.9.0",
        "youtubei.js": "^17.0.1"
    },
    "engines": {
        "node": "22"
    },
    "scripts": {
        "dev:web": "cd playlet-web && npm run dev",
        "prebuild": "node tools/rm.js dist",
        "build:dev": "npm run prebuild && npm run build:web && npm run build:lib:dev && npm run build:app:dev",
        "build:dev:v2": "PLAYLET_DEVTOOLS=1 npm run build:dev",
        "build:prod": "npm run prebuild && npm run build:web && npm run build:lib:prod && npm run build:app:prod",
        "build:release": "npm run prebuild && npm run format:fix && npm run lint:fix && npm run version-sync && npm run manifest-git-hash && npm run build:prod",
        "build:app:dev": "cd playlet-app && npm run build:dev",
        "build:app:prod": "cd playlet-app && npm run build:prod",
        "build:lib:dev": "cd playlet-lib && npm run build:dev",
        "build:lib:prod": "cd playlet-lib && npm run build:prod",
        "build:web": "cd playlet-web && npm run build",
        "build:playground": "cd playground && npm run build",
        "lint": "cd playlet-lib && npm run lint && cd ../playlet-app && npm run lint && cd ../playlet-web && npm run lint",
        "lint:fix": "cd playlet-lib && npm run lint:fix && cd ../playlet-app && npm run lint:fix && cd ../playlet-web && npm run lint",
        "format": "cd playlet-lib && npm run format && cd ../playlet-app && npm run format",
        "format:fix": "cd playlet-lib && npm run format:fix && cd ../playlet-app && npm run format:fix",
        "test": "npm run test:lib && npm run test:app",
        "test:v2": "npm run test:v2:lib && npm run test:v2:app",
        "test:v2:lib": "cd playlet-lib && npm run test:v2",
        "test:v2:app": "cd playlet-app && npm run test:v2",
        "test:build": "npm run test:build:lib && npm run test:build:app",
        "test:app": "cd playlet-app && npm run test",
        "test:build:app": "cd playlet-app && npm run test:build",
        "test:lib": "cd playlet-lib && npm run test",
        "test:build:lib": "cd playlet-lib && npm run test:build",
        "test:integration": "npx tsx ./integration-tests/play-video.ts",
        "test:integration:player": "npx tsx ./integration-tests/vpd-run-player.ts",
        "version-sync": "node tools/version-sync.js",
        "manifest-git-hash": "node tools/update-manifest-git-hash.js",
        "sign-released-package": "node tools/sign-released-package.js",
        "screenshot": "node tools/screenshot.js",
        "convert-images": "node tools/convert-images.js",
        "update-rale-component": "cd tools/RALE && rm TrackerTask.xml && curl -o TrackerTask.zip https://devtools.web.roku.com/roku-advanced-layout-editor/app/TrackerTask.zip && unzip TrackerTask.zip && rm TrackerTask.zip",
        "postinstall": "cd playlet-lib && npm install && cd ../playlet-app && npm install && cd ../playground && npm install && cd ../playlet-web && npm install",
        "update-deps": "npx npm-check-updates --deep --upgrade --install always --reject typescript,svelte-preprocess",
        "registry:write": "node tools/registry.js --input registry.json",
        "registry:read": "node tools/registry.js --output registry.json",
        "registry:clear": "node tools/registry.js --clear",
        "restart-app": "node tools/restart-app.js",
        "check-for-updates": "node tools/check-for-updates.js",
        "shutdown": "node tools/shutdown.js"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.61.1"
    }
}
